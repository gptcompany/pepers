[Unit]
Description=PePeRS - MCP Server (SSE)
# Adjust /opt/pepers paths below to match your installation directory
After=network.target rp-orchestrator.service
PartOf=rp-pipeline.target

[Service]
Type=simple
WorkingDirectory=/opt/pepers
Environment=RP_MCP_PORT=8776
Environment=RP_ORCHESTRATOR_URL=http://localhost:8775
Environment=RP_MCP_FLAVOR=arcade
ExecStart=/opt/pepers/.venv/bin/python -m services.mcp
Restart=always
RestartSec=5

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/pepers/data

[Install]
WantedBy=rp-pipeline.target
