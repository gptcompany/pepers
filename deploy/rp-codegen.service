[Unit]
Description=PePeRS - Codegen Service
After=network.target
PartOf=rp-pipeline.target

[Service]
Type=simple
WorkingDirectory=/media/sam/1TB/pepers
Environment=RP_DB_PATH=data/research.db
Environment=RP_CODEGEN_PORT=8774
ExecStart=/media/sam/1TB/pepers/.venv/bin/python -m services.codegen.main
Restart=always
RestartSec=5
WatchdogSec=60

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/media/sam/1TB/pepers/data

[Install]
WantedBy=rp-pipeline.target
