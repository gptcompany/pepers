[Unit]
Description=PePeRS - Discovery Service
# Adjust /opt/pepers paths below to match your installation directory
After=network.target
PartOf=rp-pipeline.target

[Service]
Type=simple
WorkingDirectory=/opt/pepers
Environment=RP_DB_PATH=data/research.db
Environment=RP_DISCOVERY_PORT=8770
ExecStart=/opt/pepers/.venv/bin/python -m services.discovery.main
Restart=always
RestartSec=5
WatchdogSec=60

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/pepers/data

[Install]
WantedBy=rp-pipeline.target
