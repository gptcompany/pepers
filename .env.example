# PePeRS Environment Configuration
# Copy this file to .env and configure:
#   cp .env.example .env
#
# For encrypted secrets, use dotenvx:
#   dotenvx set GEMINI_API_KEY <your-key> -f .env

# ── Database ─────────────────────────────────────────────────
RP_DB_PATH=data/research.db
RP_DATA_DIR=data
# Docker data mount (absolute path recommended for production)
# PEPERS_DATA_DIR=/media/sam/1TB/pepers/data
# Host path to the pepers repo root (used for relative extractor host-path mapping)
# PEPERS_PROJECT_HOST_DIR=/media/sam/1TB/pepers
RP_LOG_LEVEL=INFO

# ── Service Ports ────────────────────────────────────────────
RP_DISCOVERY_PORT=8770
RP_ANALYZER_PORT=8771
RP_EXTRACTOR_PORT=8772
RP_VALIDATOR_PORT=8773
RP_CODEGEN_PORT=8774
RP_ORCHESTRATOR_PORT=8775
RP_MCP_PORT=8776

# ── Discovery ────────────────────────────────────────────────
RP_DISCOVERY_SOURCES=arxiv
# RP_DISCOVERY_MAX_RESULTS=50

# ── Analyzer ─────────────────────────────────────────────────
RP_ANALYZER_THRESHOLD=0.7
RP_ANALYZER_MAX_PAPERS=10
RP_MAX_FORMULAS_DEFAULT=100
RP_LLM_TEMPERATURE=0.0
RP_LLM_SEED=42
# Analyzer runtime defaults tuned for OAuth-backed Gemini CLI and local Ollama.
# RP_GEMINI_CLI_USE_OAUTH=true
# RP_ANALYZER_LLM_FALLBACK_ORDER=gemini_cli,gemini_sdk
# RP_LLM_TIMEOUT_GEMINI_CLI=60
# RP_LLM_TIMEOUT_OLLAMA=120
# RP_LLM_FALLBACK_ORDER=gemini_cli,codex_cli,claude_cli,openrouter,ollama

# ── Extractor ────────────────────────────────────────────────
RP_EXTRACTOR_MAX_PAPERS=10
RP_EXTRACTOR_RAG_URL=http://localhost:8767
RP_EXTRACTOR_RAG_REQUEST_TIMEOUT=30
RP_EXTRACTOR_RAG_SUBMIT_TIMEOUT=60
RP_EXTRACTOR_RAG_JOB_TIMEOUT=14400
RP_EXTRACTOR_RAG_POLL_INTERVAL=30
# Optional parser override for debugging/problem papers: mineru, docling, paddleocr
# RP_EXTRACTOR_RAG_FORCE_PARSER=docling
# Shared RAGAnything data root on the host. Legacy RAG_DATA_HOST is still honored.
# RAG_DATA_PATH=/media/sam/1TB/rag-service/data
# RAG_DATA_HOST=/media/sam/1TB/rag-service/data

# ── Validator ────────────────────────────────────────────────
RP_VALIDATOR_CAS_URL=http://localhost:8769
RP_VALIDATOR_ENGINES=sympy,sage

# ── Codegen ──────────────────────────────────────────────────
RP_CODEGEN_OLLAMA_URL=http://localhost:11434
# Optional per-service overrides remain supported:
# RP_VALIDATOR_MAX_FORMULAS=100
# RP_CODEGEN_MAX_FORMULAS=100

# ── Orchestrator ─────────────────────────────────────────────
RP_RAG_QUERY_URL=http://localhost:8767
RP_ORCHESTRATOR_CRON=0 8 * * *
RP_ORCHESTRATOR_CRON_ENABLED=false
RP_ORCHESTRATOR_STAGES_PER_RUN=5
RP_ORCHESTRATOR_DEFAULT_QUERY=abs:"Kelly criterion" AND cat:q-fin.*

# ── MCP Server ───────────────────────────────────────────────
RP_MCP_FLAVOR=arcade

# ── Notifications (optional) ─────────────────────────────────
# RP_NOTIFY_URLS=discord://webhook_id/webhook_token

# ── API Keys (use dotenvx for encrypted storage) ─────────────
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
